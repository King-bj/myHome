---
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
import SearchModal from '../components/common/SearchModal.astro';
import { getLangFromUrl } from '../i18n';
import { siteConfig } from '../data/site';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  lang?: string;
  image?: string;
  /** When zh/en article slugs differ, mobile header language toggle uses this instead of prefixing /en. */
  altLangUrl?: string | null;
}

const { title, description, lang, image, altLangUrl } = Astro.props;
const currentLang = lang || getLangFromUrl(Astro.url);

const siteTitle = title || (currentLang === 'en' ? siteConfig.titleEn : siteConfig.title);
const siteDescription = description || (currentLang === 'en' ? siteConfig.descriptionEn : siteConfig.description);
const ogImage = image || siteConfig.avatar;
const canonicalUrl = Astro.url.href;
---

<!DOCTYPE html>
<html lang={currentLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={siteDescription} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{siteTitle}</title>

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={currentLang === 'en' ? 'en_US' : 'zh_CN'} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={siteDescription} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <!-- Theme initialization -->
    <script is:inline>
      const theme = localStorage.getItem('theme') ||
        (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.classList.toggle('dark', theme === 'dark');
    </script>
  </head>
  <body class="min-h-screen">
    <Header lang={currentLang} altLangUrl={altLangUrl ?? undefined} />
    <main class="pt-16 md:pt-0">
      <slot />
    </main>
    <Footer lang={currentLang} />
    <SearchModal />
  </body>
</html>
