---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/projects/ProjectCard.astro';
import ArticleCard from '../components/articles/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations } from '../i18n';
import { siteConfig } from '../data/site';
import { homeShowcaseImages } from '../data/homeShowcase';

const lang = getLangFromUrl(Astro.url) || 'zh';
const t = useTranslations(lang as 'zh' | 'en');

const allProjects = await getCollection('projects');
const allArticles = await getCollection('articles');

const featuredProjects = allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);

// Filter articles by language (zh articles are in zh/ subdirectory)
const langPrefix = lang === 'en' ? 'en/' : 'zh/';
const recentArticles = allArticles
  .filter(a => !a.data.draft && a.slug.startsWith(langPrefix))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const prefix = lang === 'en' ? '/en' : '';
const currentPath = Astro.url.pathname;
const homeNavItems = [
  { href: `${prefix}/`, label: t('nav.home') },
  { href: `${prefix}/articles`, label: t('nav.articles') },
  { href: `${prefix}/projects`, label: t('nav.projects') },
  { href: `${prefix}/about`, label: t('nav.about') },
];
---

<BaseLayout lang={lang}>
    <main class="p-4 md:p-8">
      <div class="max-w-5xl mx-auto">
        <nav class="home-top-nav mb-6">
          {homeNavItems.map((item) => (
            <a
              href={item.href}
              class:list={['home-top-nav-link', {
                'active': currentPath === item.href || (item.href !== `${prefix}/` && currentPath.startsWith(item.href + '/'))
              }]}
            >
              {item.label}
            </a>
          ))}
        </nav>

        <section class="first-visit-panel hero-accent card mb-10 p-6 md:p-9">
          <div class="first-visit-head mb-4">
            <img src={siteConfig.avatar} alt={siteConfig.name} class="first-visit-avatar" />
            <p class="text-sm font-medium" style="color: var(--color-accent);">
              {t('home.firstVisitLead')}
            </p>
          </div>
          <h1 class="first-visit-title">
            <span>{t('home.firstVisitHeadlineLine1')}</span>
          </h1>
          <p class="first-visit-description mt-4">
            {t('home.firstVisitDescription')}
          </p>
          <div class="first-visit-links mt-6 flex-wrap">
            <a href={`/${lang === 'en' ? 'en/' : ''}articles`} class="button-primary">
              {t('home.latestArticles')}
            </a>
            <a href={`/${lang === 'en' ? 'en/' : ''}projects`} class="button-secondary">
              {t('home.featuredProjects')}
            </a>
            <a href={siteConfig.social.github} target="_blank" rel="noopener noreferrer" class="link">GitHub</a>
          </div>
        </section>

        {siteConfig.features.showHomePhotoWall && (
          <section class="photo-wall-band mb-10">
            <div class="photo-wall">
              {homeShowcaseImages.map((item) => (
                item.href ? (
                  <a href={item.href} target="_blank" rel="noopener noreferrer" class="photo-wall-item">
                    <img src={item.src} alt={item.altZh} loading="lazy" />
                  </a>
                ) : (
                  <div class="photo-wall-item">
                    <img src={item.src} alt={item.altZh} loading="lazy" />
                  </div>
                )
              ))}
            </div>
          </section>
        )}

        <!-- Recent Articles -->
        <section class="mb-12">
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-semibold" style="color: var(--color-text-primary);">
              {t('home.latestArticles')}
            </h2>
            <a href={`/${lang === 'en' ? 'en/' : ''}articles`} class="link text-sm flex items-center gap-1">
              {t('home.viewAll')}
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m9 18 6-6-6-6"/>
              </svg>
            </a>
          </div>
          <p class="text-sm mb-4" style="color: var(--color-text-muted);">
            {t('home.latestArticlesHint')}
          </p>
          <div class="space-y-4">
            {recentArticles.map((article) => (
              <ArticleCard
                title={article.data.title}
                description={article.data.description}
                pubDate={article.data.pubDate}
                tags={article.data.tags}
                cover={article.data.cover}
                slug={article.slug.replace(langPrefix, '')}
                lang={lang}
              />
            ))}
          </div>

          {recentArticles.length === 0 && (
            <p class="text-center py-8" style="color: var(--color-text-muted);">
              {lang === 'en' ? 'No articles yet' : '暂无文章'}
            </p>
          )}
        </section>

        <section>
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-semibold" style="color: var(--color-text-primary);">
              {t('home.featuredProjects')}
            </h2>
            <a href={`/${lang === 'en' ? 'en/' : ''}projects`} class="link text-sm flex items-center gap-1">
              {t('home.viewAll')}
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m9 18 6-6-6-6"/>
              </svg>
            </a>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {featuredProjects.map((project) => (
              <ProjectCard
                name={project.data.name}
                nameEn={project.data.nameEn}
                description={project.data.description}
                descriptionEn={project.data.descriptionEn}
                techStack={project.data.techStack}
                github={project.data.github}
                demo={project.data.demo}
                thumbnail={project.data.thumbnail}
                status={project.data.status}
                lang={lang}
              />
            ))}
          </div>

          {featuredProjects.length === 0 && (
            <p class="text-center py-8" style="color: var(--color-text-muted);">
              {lang === 'en' ? 'No projects yet' : '暂无项目'}
            </p>
          )}
        </section>

      </div>
    </main>
</BaseLayout>
