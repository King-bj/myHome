---
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/common/Sidebar.astro';
import ProjectCard from '../components/projects/ProjectCard.astro';
import ArticleCard from '../components/articles/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations } from '../i18n';

const lang = getLangFromUrl(Astro.url) || 'zh';
const t = useTranslations(lang as 'zh' | 'en');

const allProjects = await getCollection('projects');
const allArticles = await getCollection('articles');

const featuredProjects = allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);

// Filter articles by language (zh articles are in zh/ subdirectory)
const langPrefix = lang === 'en' ? 'en/' : 'zh/';
const recentArticles = allArticles
  .filter(a => !a.data.draft && a.slug.startsWith(langPrefix))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<BaseLayout lang={lang}>
  <div class="flex min-h-screen">
    <Sidebar lang={lang} />

    <main class="main-content flex-1 p-4 md:p-8">
      <div class="max-w-4xl mx-auto">
        <!-- Hero Section (Mobile) -->
        <section class="mb-8 md:hidden text-center py-8">
          <h1 class="text-2xl font-bold mb-2" style="color: var(--color-text-primary);">
            {t('home.greeting')}<span class="text-accent">{lang === 'en' ? 'Zhimu Zisheng' : '植木自生'}</span>
          </h1>
          <p class="text-lg mb-2" style="color: var(--color-text-secondary);">
            {t('home.title')}
          </p>
          <p class="text-sm" style="color: var(--color-text-muted);">
            {t('home.subtitle')}
          </p>
        </section>

        <!-- Featured Projects -->
        <section class="mb-12">
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-semibold" style="color: var(--color-text-primary);">
              {t('home.featuredProjects')}
            </h2>
            <a href={`/${lang === 'en' ? 'en/' : ''}projects`} class="link text-sm flex items-center gap-1">
              {t('home.viewAll')}
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m9 18 6-6-6-6"/>
              </svg>
            </a>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {featuredProjects.map((project) => (
              <ProjectCard
                name={project.data.name}
                nameEn={project.data.nameEn}
                description={project.data.description}
                descriptionEn={project.data.descriptionEn}
                techStack={project.data.techStack}
                github={project.data.github}
                demo={project.data.demo}
                thumbnail={project.data.thumbnail}
                status={project.data.status}
                lang={lang}
              />
            ))}
          </div>

          {featuredProjects.length === 0 && (
            <p class="text-center py-8" style="color: var(--color-text-muted);">
              {lang === 'en' ? 'No projects yet' : '暂无项目'}
            </p>
          )}
        </section>

        <!-- Recent Articles -->
        <section>
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-semibold" style="color: var(--color-text-primary);">
              {t('home.latestArticles')}
            </h2>
            <a href={`/${lang === 'en' ? 'en/' : ''}articles`} class="link text-sm flex items-center gap-1">
              {t('home.viewAll')}
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m9 18 6-6-6-6"/>
              </svg>
            </a>
          </div>

          <div class="space-y-4">
            {recentArticles.map((article) => (
              <ArticleCard
                title={article.data.title}
                description={article.data.description}
                pubDate={article.data.pubDate}
                tags={article.data.tags}
                cover={article.data.cover}
                slug={article.slug.replace(langPrefix, '')}
                lang={lang}
              />
            ))}
          </div>

          {recentArticles.length === 0 && (
            <p class="text-center py-8" style="color: var(--color-text-muted);">
              {lang === 'en' ? 'No articles yet' : '暂无文章'}
            </p>
          )}
        </section>
      </div>
    </main>
  </div>
</BaseLayout>
