---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/common/Sidebar.astro';
import ArticleCard from '../../components/articles/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations } from '../../i18n';

const lang = getLangFromUrl(Astro.url) || 'zh';
const t = useTranslations(lang as 'zh' | 'en');

const allArticles = await getCollection('articles');
// Filter articles by language (zh articles are in zh/ subdirectory)
const articles = allArticles
  .filter(a => !a.data.draft && a.slug.startsWith('zh/'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout lang={lang} title={t('articles.title')}>
  <div class="flex min-h-screen">
    <Sidebar lang={lang} />

    <main class="main-content flex-1 p-4 md:p-8">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-2xl font-bold mb-8" style="color: var(--color-text-primary);">
          {t('articles.title')}
        </h1>

        <div class="space-y-4">
          {articles.map((article) => (
            <ArticleCard
              title={article.data.title}
              description={article.data.description}
              pubDate={article.data.pubDate}
              tags={article.data.tags}
              cover={article.data.cover}
              slug={article.slug.replace('zh/', '')}
              lang={lang}
            />
          ))}
        </div>

        {articles.length === 0 && (
          <p class="text-center py-12" style="color: var(--color-text-muted);">
            {lang === 'en' ? 'No articles yet' : '暂无文章'}
          </p>
        )}
      </div>
    </main>
  </div>
</BaseLayout>
