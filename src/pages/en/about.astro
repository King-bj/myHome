---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/common/Sidebar.astro';
import { getLangFromUrl, useTranslations } from '../../i18n';

const lang = getLangFromUrl(Astro.url) || 'en';
const t = useTranslations(lang as 'zh' | 'en');
---

<BaseLayout lang={lang} title={t('about.title')}>
  <div class="flex min-h-screen">
    <Sidebar lang={lang} />

    <main class="main-content flex-1 p-4 md:p-8">
      <div class="max-w-3xl mx-auto">
        <h1 class="text-2xl font-bold mb-8" style="color: var(--color-text-primary);">
          {t('about.title')}
        </h1>

        <!-- Who I Am -->
        <section class="mb-12">
          <div class="card p-6">
            <div class="prose prose-slate dark:prose-invert max-w-none">
              <p class="text-lg mb-4" style="color: var(--color-text-secondary);">
                Backend developer with 8 years of experience, exploring the possibilities of AI-powered development.
              </p>
              <p style="color: var(--color-text-secondary);">
                I specialize in finding and fixing performance bottlenecks in complex systems—from Flink data processing to Elasticsearch query optimization, from JVM tuning to distributed architecture design. I enjoy the process of making slow systems fast.
              </p>
              <p class="mt-4" style="color: var(--color-text-secondary);">
                Currently, I'm learning how to amplify individual capabilities with AI: from Prompt Engineering to Agent development, from RAG systems to automated workflows. I believe the best developers of the future are those who can collaborate effectively with AI.
              </p>
            </div>
          </div>
        </section>

        <!-- How I Can Help -->
        <section class="mb-12">
          <h2 class="text-xl font-semibold mb-6" style="color: var(--color-text-primary);">
            How I Can Help
          </h2>

          <div class="space-y-4">
            <div class="card p-6">
              <h3 class="font-medium mb-2" style="color: var(--color-text-primary);">
                🚀 Performance Troubleshooting & Optimization
              </h3>
              <p class="text-sm" style="color: var(--color-text-secondary);">
                Slow data processing, high memory usage, sluggish queries? I can help identify bottlenecks and provide optimization strategies.
              </p>
            </div>

            <div class="card p-6">
              <h3 class="font-medium mb-2" style="color: var(--color-text-primary);">
                🏗️ Backend Architecture Design
              </h3>
              <p class="text-sm" style="color: var(--color-text-secondary);">
                Need to design a scalable data processing system? I can share practical experience from single-node to distributed clusters.
              </p>
            </div>

            <div class="card p-6">
              <h3 class="font-medium mb-2" style="color: var(--color-text-primary);">
                🤖 AI Application Development
              </h3>
              <p class="text-sm" style="color: var(--color-text-secondary);">
                Want to integrate AI capabilities into existing systems? I can help design RAG, Agents, or automated workflows.
              </p>
            </div>
          </div>
        </section>

        <!-- Currently Exploring -->
        <section class="mb-12">
          <h2 class="text-xl font-semibold mb-6" style="color: var(--color-text-primary);">
            Currently Exploring
          </h2>

          <div class="card p-6">
            <div class="flex flex-wrap gap-2">
              <span class="tag">AI Agent Development</span>
              <span class="tag">RAG Systems</span>
              <span class="tag">LLM Applications</span>
              <span class="tag">Automation Workflows</span>
              <span class="tag">Indie Developer Ecosystem</span>
            </div>
          </div>
        </section>

        <!-- Tech Stack -->
        <section>
          <h2 class="text-xl font-semibold mb-6" style="color: var(--color-text-primary);">
            Tech Stack
          </h2>

          <div class="card p-6">
            <div class="grid gap-4 md:grid-cols-2">
              <div>
                <h3 class="font-medium mb-3 text-sm" style="color: var(--color-text-muted);">
                  Backend & Big Data
                </h3>
                <div class="flex flex-wrap gap-2">
                  <span class="tag">Java</span>
                  <span class="tag">Python</span>
                  <span class="tag">Kafka</span>
                  <span class="tag">Flink</span>
                  <span class="tag">Elasticsearch</span>
                  <span class="tag">Redis</span>
                </div>
              </div>
              <div>
                <h3 class="font-medium mb-3 text-sm" style="color: var(--color-text-muted);">
                  AI & Tools
                </h3>
                <div class="flex flex-wrap gap-2">
                  <span class="tag">LangChain</span>
                  <span class="tag">Claude API</span>
                  <span class="tag">OpenAI API</span>
                  <span class="tag">Docker</span>
                  <span class="tag">K8s</span>
                </div>
              </div>
            </div>
          </div>
        </section>
      </div>
    </main>
  </div>
</BaseLayout>
