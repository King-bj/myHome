---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ProjectCard from '../../../components/projects/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations } from '../../../i18n';

const lang = getLangFromUrl(Astro.url) || 'en';
const t = useTranslations(lang as 'zh' | 'en');

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => a.data.order - b.data.order);
const homeNavItems = [
  { href: '/en/', label: t('nav.home') },
  { href: '/en/articles', label: t('nav.articles') },
  { href: '/en/projects', label: t('nav.projects') },
  { href: '/en/about', label: t('nav.about') },
];
const currentPath = Astro.url.pathname;
---

<BaseLayout lang={lang} title={t('projects.title')}>
  <main class="p-4 md:p-8">
    <div class="max-w-4xl mx-auto">
      <nav class="home-top-nav mb-6">
        {homeNavItems.map((item) => (
          <a
            href={item.href}
            class:list={['home-top-nav-link', {
              'active': currentPath === item.href || (item.href !== '/en/' && currentPath.startsWith(item.href + '/'))
            }]}
          >
            {item.label}
          </a>
        ))}
      </nav>

        <h1 class="text-2xl font-bold mb-8" style="color: var(--color-text-primary);">
          {t('projects.title')}
        </h1>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {projects.map((project) => (
            <ProjectCard
              name={project.data.name}
              nameEn={project.data.nameEn}
              description={project.data.description}
              descriptionEn={project.data.descriptionEn}
              techStack={project.data.techStack}
              github={project.data.github}
              demo={project.data.demo}
              thumbnail={project.data.thumbnail}
              status={project.data.status}
              lang={lang}
            />
          ))}
        </div>

        {projects.length === 0 && (
          <p class="text-center py-12" style="color: var(--color-text-muted);">
            {lang === 'en' ? 'No projects yet' : '暂无项目'}
          </p>
        )}
    </div>
  </main>
</BaseLayout>
