---
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');

// Prepare search data
const searchData = articles
  .filter(a => !a.data.draft)
  .map(article => {
    // Determine language from slug
    const isEn = article.slug.startsWith('en/');
    const lang = isEn ? 'en' : 'zh';
    const cleanSlug = article.slug.replace(/^(en|zh)\//, '');

    return {
      slug: article.slug,
      cleanSlug: cleanSlug,
      lang: lang,
      title: article.data.title,
      description: article.data.description,
      tags: article.data.tags,
      pubDate: article.data.pubDate.toISOString(),
    };
  });

const searchDataJson = JSON.stringify(searchData);
---

<!-- Search Modal -->
<div class="search-modal hidden" id="__search-modal">
  <div class="search-backdrop" onclick="__closeSearch()"></div>
  <div class="search-dialog">
    <div class="search-input-wrapper">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"></circle>
        <path d="m21 21-4.3-4.3"></path>
      </svg>
      <input
        type="text"
        id="__search-input"
        class="search-input"
        placeholder="搜索文章标题、描述或标签..."
        autocomplete="off"
        oninput="__performSearch(this.value)"
      />
      <button class="search-close" aria-label="Close search" type="button" onclick="__closeSearch()">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 6 6 18"></path>
          <path d="m6 6 12 12"></path>
        </svg>
      </button>
    </div>
    <div id="__search-results" class="search-results"></div>
  </div>
</div>

<style is:global>
  /* Modal */
  .search-modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    min-width: 100vw;
    min-height: 100vh;
  }

  .search-modal.hidden {
    display: none !important;
  }

  .search-backdrop {
    position: absolute;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
  }

  .search-dialog {
    position: absolute;
    top: 15%;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    max-width: 36rem;
    margin: 0 1rem;
    border-radius: 0.75rem;
    overflow: hidden;
    background-color: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
  }

  .search-input-wrapper {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .search-input-wrapper svg {
    flex-shrink: 0;
    color: var(--color-text-muted);
  }

  .search-input {
    flex: 1;
    background: transparent;
    outline: none;
    font-size: 1rem;
    color: var(--color-text-primary);
  }

  .search-input::placeholder {
    color: var(--color-text-muted);
  }

  .search-close {
    padding: 0.25rem;
    border-radius: 0.5rem;
    transition: all 0.2s;
    color: var(--color-text-muted);
    background: transparent;
    border: none;
    cursor: pointer;
  }

  .search-close:hover {
    background-color: var(--color-bg-tertiary);
    color: var(--color-text-primary);
  }

  .search-results {
    max-height: 60vh;
    overflow-y: auto;
    padding: 0.5rem;
  }

  .search-result-item {
    display: block;
    padding: 0.75rem;
    border-radius: 0.5rem;
    transition: background-color 0.2s;
  }

  .search-result-item:hover {
    background-color: var(--color-bg-tertiary);
  }

  .search-result-title {
    font-weight: 500;
    margin-bottom: 0.25rem;
    color: var(--color-text-primary);
  }

  .search-result-desc {
    font-size: 0.875rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    color: var(--color-text-secondary);
  }

  .search-result-tags {
    display: flex;
    gap: 0.25rem;
    margin-top: 0.5rem;
  }

  .search-result-tag {
    font-size: 0.75rem;
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    background-color: var(--color-bg-tertiary);
    color: var(--color-text-muted);
  }

  .search-empty {
    padding: 2rem 0;
    text-align: center;
    color: var(--color-text-muted);
  }
</style>

<script is:inline define:vars={{ searchDataJson }}>
  // Initialize search data
  window.__searchData = JSON.parse(searchDataJson);

  // Global functions
  window.__openSearch = function() {
    var modal = document.getElementById('__search-modal');
    var input = document.getElementById('__search-input');
    if (modal && input) {
      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      setTimeout(function() { input.focus(); }, 50);
    }
  };

  window.__closeSearch = function() {
    var modal = document.getElementById('__search-modal');
    var input = document.getElementById('__search-input');
    var results = document.getElementById('__search-results');
    if (modal && input && results) {
      modal.classList.add('hidden');
      input.value = '';
      results.innerHTML = '';
      document.body.style.overflow = '';
    }
  };

  window.__performSearch = function(query) {
    var results = document.getElementById('__search-results');
    if (!results) return;

    if (!query.trim()) {
      results.innerHTML = '';
      return;
    }

    var q = query.toLowerCase();
    var data = window.__searchData || [];
    var matches = data.filter(function(article) {
      var titleMatch = article.title.toLowerCase().indexOf(q) > -1;
      var descMatch = article.description.toLowerCase().indexOf(q) > -1;
      var tagMatch = article.tags.some(function(tag) { return tag.toLowerCase().indexOf(q) > -1; });
      return titleMatch || descMatch || tagMatch;
    });

    if (matches.length === 0) {
      results.innerHTML = '<div class="search-empty">没有找到相关文章</div>';
      return;
    }

    var html = '';
    for (var i = 0; i < matches.length; i++) {
      var article = matches[i];
      var tagsHtml = article.tags.slice(0, 3).map(function(tag) {
        return '<span class="search-result-tag">' + tag + '</span>';
      }).join('');

      // Build URL based on language
      var url = article.lang === 'en'
        ? '/en/articles/' + article.cleanSlug
        : '/articles/' + article.cleanSlug;

      html += '<a href="' + url + '" class="search-result-item" onclick="__closeSearch()">' +
        '<div class="search-result-title">' + article.title + '</div>' +
        '<div class="search-result-desc">' + article.description + '</div>' +
        '<div class="search-result-tags">' + tagsHtml + '</div>' +
        '</a>';
    }
    results.innerHTML = html;
  };

  // Keyboard shortcuts
  document.addEventListener('keydown', function(e) {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      window.__openSearch();
    }
    if (e.key === 'Escape') {
      var modal = document.getElementById('__search-modal');
      if (modal && !modal.classList.contains('hidden')) {
        window.__closeSearch();
      }
    }
  });
</script>
