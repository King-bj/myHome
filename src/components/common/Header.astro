---
import ThemeToggle from './ThemeToggle';
import LanguageSwitch from './LanguageSwitch';
import SearchButton from './SearchButton.astro';
import { getLangFromUrl, useTranslations } from '../../i18n';
import '../../styles/global.css';

interface Props {
  lang?: string;
}

const { lang } = Astro.props;
const currentLang = lang || getLangFromUrl(Astro.url);
const t = useTranslations(currentLang as 'zh' | 'en');

const navItems = [
  { href: '/', label: t('nav.home') },
  { href: '/projects', label: t('nav.projects') },
  { href: '/articles', label: t('nav.articles') },
  { href: '/videos', label: t('nav.videos') },
  { href: '/about', label: t('nav.about') },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 border-b backdrop-blur-sm md:hidden" style="background-color: rgba(255, 255, 255, 0.9); border-color: var(--color-border);">
  <nav class="flex items-center justify-between h-16 px-4">
    <!-- Logo -->
    <a href="/" class="text-lg font-bold" style="color: var(--color-text-primary);">
      植木自生
    </a>

    <!-- Actions -->
    <div class="flex items-center gap-2">
      <SearchButton />
      <LanguageSwitch client:load />
      <ThemeToggle client:load />
    </div>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="p-2 rounded-lg"
      style="color: var(--color-text-secondary);"
      aria-label="Toggle menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="4" x2="20" y1="12" y2="12"></line>
        <line x1="4" x2="20" y1="6" y2="6"></line>
        <line x1="4" x2="20" y1="18" y2="18"></line>
      </svg>
    </button>
  </nav>

  <!-- Mobile Navigation -->
  <div id="mobile-menu" class="hidden border-t" style="border-color: var(--color-border); background-color: var(--color-bg-secondary);">
    <div class="px-4 py-3 space-y-1">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={['block px-3 py-2 rounded-lg text-sm', {
            'font-medium': currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))
          }]}
          style={currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))
            ? 'color: var(--color-accent)'
            : 'color: var(--color-text-secondary)'}
        >
          {item.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>

<style>
  .dark header {
    background-color: rgba(15, 23, 42, 0.9);
  }
</style>
