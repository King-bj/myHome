---
interface TocItem {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  items: TocItem[];
  variant?: 'mobile' | 'desktop';
  title: string;
}

const { items, variant = 'mobile', title } = Astro.props;
const isMobile = variant === 'mobile';
---

{items.length > 0 && (
  <nav class="toc-wrapper" aria-label={title}>
    {isMobile ? (
      <!-- Mobile TOC (collapsible inline) -->
      <details class="toc-mobile">
        <summary class="toc-summary">
          <span class="font-semibold" style="color: var(--color-text-primary);">{title}</span>
          <svg class="toc-chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </summary>
        <ul class="toc-list">
          {items.map((item) => (
            <li class={`toc-item toc-depth-${item.depth}`}>
              <a href={`#${item.slug}`} class="toc-link">
                {item.text}
              </a>
            </li>
          ))}
        </ul>
      </details>
    ) : (
      <!-- Desktop TOC: fixed to viewport, does not consume layout width -->
      <div class="toc-fixed">
        <h4 class="toc-title">{title}</h4>
        <ul class="toc-list">
          {items.map((item) => (
            <li class={`toc-item toc-depth-${item.depth}`}>
              <a href={`#${item.slug}`} class="toc-link">
                {item.text}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </nav>
)}

<style>
  /* Mobile TOC */
  .toc-mobile {
    @apply mb-6 rounded-lg p-4;
    background-color: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
  }

  .toc-summary {
    @apply flex items-center justify-between cursor-pointer list-none;
    color: var(--color-text-primary);
  }

  .toc-summary::-webkit-details-marker {
    display: none;
  }

  .toc-chevron {
    @apply transition-transform duration-200;
  }

  .toc-mobile[open] .toc-chevron {
    @apply rotate-180;
  }

  /* Desktop TOC: fixed in viewport, to the right of a centered max-w-3xl (48rem) column */
  .toc-fixed {
    @apply p-4 rounded-lg;
    position: fixed;
    top: 1.25rem;
    width: 13.75rem;
    max-width: min(13.75rem, calc(100vw - 1.5rem));
    max-height: calc(100vh - 2rem);
    overflow-y: auto;
    z-index: 20;
    left: min(calc(50vw + 24rem + 1rem), calc(100vw - 14rem - 1rem));
    background-color: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
  }

  .toc-title {
    @apply text-sm font-semibold mb-3;
    color: var(--color-text-primary);
  }

  /* Shared list styles */
  .toc-list {
    @apply space-y-1;
  }

  .toc-mobile .toc-list {
    @apply mt-3;
  }

  .toc-item {
    @apply list-none;
  }

  .toc-depth-2 {
    @apply ml-0;
  }

  .toc-depth-3 {
    @apply ml-3;
  }

  .toc-depth-4 {
    @apply ml-6;
  }

  .toc-link {
    @apply block py-1 px-2 rounded text-sm transition-colors;
    color: var(--color-text-secondary);
  }

  .toc-link:hover {
    background-color: var(--color-bg-tertiary);
    color: var(--color-accent);
  }

  .toc-link.active {
    color: var(--color-accent);
    background-color: var(--color-bg-tertiary);
  }
</style>

<script>
  // Track active section on scroll
  const tocLinks = document.querySelectorAll('.toc-link');
  const headings = document.querySelectorAll('article h2, article h3, article h4');

  if (tocLinks.length > 0 && headings.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const id = entry.target.getAttribute('id');
          if (id && entry.isIntersecting) {
            tocLinks.forEach((link) => {
              link.classList.remove('active');
              if (link.getAttribute('href') === `#${id}`) {
                link.classList.add('active');
              }
            });
          }
        });
      },
      {
        rootMargin: '-80px 0px -80% 0px',
      }
    );

    headings.forEach((heading) => {
      observer.observe(heading);
    });
  }
</script>
