---
import { getArticleCategory } from '../../data/articleTaxonomy';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  cover?: string;
  slug: string;
  lang?: string;
}

const { title, description, pubDate, tags, cover, slug, lang = 'zh' } = Astro.props;

const prefix = lang === 'en' ? '/en' : '';
const articleUrl = `${prefix}/articles/${slug}`;
const category = getArticleCategory(tags, lang as 'zh' | 'en');

const formattedDate = pubDate.toLocaleDateString(lang === 'en' ? 'en-US' : 'zh-CN', {
  year: 'numeric',
  month: 'short',
  day: 'numeric'
});
---

<article class="card group flex flex-col md:flex-row overflow-hidden">
  <!-- Cover Image -->
  {cover && (
    <div class="w-full md:w-48 shrink-0 aspect-video md:aspect-square overflow-hidden relative" style="background-color: var(--color-bg-tertiary);">
      <img
        src={cover}
        alt={title}
        class="w-full h-full object-contain group-hover:scale-105 transition-transform duration-300"
        onerror="this.onerror=null; this.style.display='none'; this.nextElementSibling.style.display='flex';"
      />
      <!-- Placeholder when image fails -->
      <div class="absolute inset-0 hidden items-center justify-center" style="background-color: var(--color-bg-tertiary);">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-text-muted);">
          <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="16" x2="8" y1="13" y2="13"/>
          <line x1="16" x2="8" y1="17" y2="17"/>
          <line x1="10" x2="8" y1="9" y2="9"/>
        </svg>
      </div>
    </div>
  )}

  <!-- Content -->
  <div class="p-4 flex-1">
    <div class="flex items-center gap-2 mb-2 flex-wrap">
      <time class="text-xs" style="color: var(--color-text-muted);">
        {formattedDate}
      </time>
      <span class="category-chip">{category.label}</span>
    </div>

    <h3 class="font-semibold mb-2 text-lg" style="color: var(--color-text-primary);">
      <a href={articleUrl} class="transition-colors hover:opacity-90">
        {title}
      </a>
    </h3>

    <p class="text-sm mb-3 line-clamp-2" style="color: var(--color-text-secondary);">
      {description}
    </p>

    <!-- Tags -->
    <div class="flex flex-wrap gap-1.5">
      {tags.slice(0, 3).map((tag) => (
        <span class="tag">{tag}</span>
      ))}
    </div>
  </div>
</article>
