---
interface Props {
  name: string;
  nameEn?: string;
  description: string;
  descriptionEn?: string;
  techStack: string[];
  github?: string;
  demo?: string;
  thumbnail: string;
  status?: 'completed' | 'in-progress' | 'archived';
  lang?: string;
}

const { name, nameEn, description, descriptionEn, techStack, github, demo, thumbnail, status = 'completed', lang = 'zh' } = Astro.props;

const displayName = lang === 'en' && nameEn ? nameEn : name;
const displayDesc = lang === 'en' && descriptionEn ? descriptionEn : description;

const statusLabels = {
  zh: { completed: '已完成', 'in-progress': '进行中', archived: '已归档' },
  en: { completed: 'Completed', 'in-progress': 'In Progress', archived: 'Archived' }
};
---

<article class="card group">
  <!-- Thumbnail -->
  <div class="aspect-video overflow-hidden relative" style="background-color: var(--color-bg-tertiary);">
    <img
      src={thumbnail}
      alt={displayName}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
      onerror="this.onerror=null; this.style.display='none'; this.nextElementSibling.style.display='flex';"
    />
    <!-- Placeholder when image fails -->
    <div class="absolute inset-0 hidden items-center justify-center" style="background-color: var(--color-bg-tertiary);">
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-text-muted);">
        <rect width="18" height="18" x="3" y="3" rx="2" ry="2"/>
        <circle cx="9" cy="9" r="2"/>
        <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
      </svg>
    </div>
  </div>

  <!-- Content -->
  <div class="p-4">
    <div class="flex items-start justify-between gap-2 mb-2">
      <h3 class="font-semibold text-lg" style="color: var(--color-text-primary);">
        {displayName}
      </h3>
      <span class="tag shrink-0">
        {statusLabels[lang as 'zh' | 'en'][status]}
      </span>
    </div>

    <p class="text-sm mb-3 line-clamp-2" style="color: var(--color-text-secondary);">
      {displayDesc}
    </p>

    <!-- Tech Stack -->
    <div class="flex flex-wrap gap-1.5 mb-3">
      {techStack.slice(0, 4).map((tech) => (
        <span class="tag">{tech}</span>
      ))}
    </div>

    <!-- Links -->
    <div class="flex items-center gap-3">
      {github && (
        <a
          href={github}
          target="_blank"
          rel="noopener noreferrer"
          class="link text-sm flex items-center gap-1"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path>
            <path d="M9 18c-4.51 2-5-2-7-2"></path>
          </svg>
          GitHub
        </a>
      )}
      {demo && (
        <a
          href={demo}
          target="_blank"
          rel="noopener noreferrer"
          class="link text-sm flex items-center gap-1"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 3h6v6"></path>
            <path d="M10 14 21 3"></path>
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
          </svg>
          {lang === 'en' ? 'Demo' : '演示'}
        </a>
      )}
    </div>
  </div>
</article>
